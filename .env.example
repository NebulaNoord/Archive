# Resend API key — create one at https://resend.com/api-keys
# This key must stay secret. Never commit the real value.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form messages are delivered
CONTACT_TO=nebulanoord@gmail.com

# Verified sender. onboarding@resend.dev works in Resend test mode
# (only delivers to your own verified account email). For production,
# verify a domain and use e.g. hello@nebulanoord.com.
CONTACT_FROM=onboarding@resend.dev
